# LGPD Sentinel AI - Environment Variables
# Copie este arquivo para .env e ajuste os valores

# App
DEBUG=false
LOG_LEVEL=INFO

# Ollama (IA local gratuita)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Supabase (opcional - free tier)
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_ANON_KEY=sua-chave-anon
# SUPABASE_SERVICE_KEY=sua-chave-service

# Relatorios PDF
REPORTS_DIR=/tmp/lgpd_reports
REPORT_COMPANY_NAME=Minha Empresa

# Limiares de risco (0.0 a 1.0)
RISK_HIGH_THRESHOLD=0.7
RISK_MEDIUM_THRESHOLD=0.4

# CORS (separar origens por virgula)
CORS_ORIGINS=["http://localhost:3000"]
