{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LGPD Sentinel AI",
  "version": "1.0.0",
  "identifier": "com.lgpdsentinel.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LGPD Sentinel AI",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Auditoria LGPD com IA local",
    "longDescription": "Ferramenta open source de auditoria LGPD com IA local. Data Mapping, DPIA, DSR — tudo rodando na sua máquina, sem enviar dados para a nuvem.",
    "copyright": "© 2026 LGPD Sentinel AI Contributors",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "resources": [
      "resources/backend/**/*"
    ]
  }
}
